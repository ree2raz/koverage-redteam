# Copy to .env and fill in. The harness reads these via llmcore.config.settings.

# --- Self-hosted target (default, ban-safe) --------------------------------
# Root URL printed by `modal deploy deploy/modal_gpt_oss.py`.
# The harness appends /v1 itself — do NOT include /v1 here.
MODAL_OSS_URL=
# Any non-empty string; Modal public web endpoints don't check it.
MODAL_OSS_API_KEY=modal

# --- Hosted gateway (OPTIONAL) ---------------------------------------------
# Only for AUTHORIZED targets, the attacker-generation model, or the judge.
# Do NOT point the red-team target at a hosted frontier model without written
# authorization — it violates provider ToS and risks account termination.
OPENROUTER_API_KEY=
